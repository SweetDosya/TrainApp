#:import NavigationScreenManager libs.screens_py.exercises_navigation.NavigationScreenManager

<ExercisesScreen>:
    id: main_exercs
    name: "main_exercises"

    NavigationExerciseManager:
        id: exerc_manager
        name: "exercise_manager"

        MainExerciseScreen:
            id: main_exerc
            name: "main_exercise"

        CreateProgramScreen:

        ExerciseDescrScreen

        ProgramsNotFoundScreen:

        WorkoutProgramsScreen:

        #WorkoutProgramDescrScreen:

        #WorkoutProgramTrainScreen

        #WorkoutProgramExerciseScreen:

<ExerciseDescrScreen>:
    name: "exercise_description"
    ScrollView:
        BoxLayout:
            orientation: 'vertical'
            padding: '10dp'
            spacing: '10dp'

            MDLabel:
                id: exercise_name
                size_hint_y: None
                height: self.texture_size[1] + dp(20)
                text: "Назва Вправи"
                halign: "center"
                font_style: "H4"

            BoxLayout:
                orientation: 'horizontal'
                size_hint_y: None
                height: self.minimum_height
                padding: '10dp'
                spacing: '10dp'
                MDLabel:
                    id: muscle_group
                    text: "Група м'язів"
                    halign: "center"
                    font_style: "Subtitle1"

                BoxLayout:
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: '10dp'
                    MDLabel:
                        text: "Складність:"
                        font_style: "Subtitle1"

                    BoxLayout:
                        size_hint_x: 1.2
                        spacing: '25dp'
                        MDIcon:
                            id: star_1
                            icon: "star-outline"
                        MDIcon:
                            id: star_2
                            icon: "star-outline"
                        MDIcon:
                            id: star_3
                            icon: "star-outline"

            MDSeparator:
                id: separator1

            StackLayout:
                id: muscles_info
                padding: [10, 10, 10, 0]
                spacing: '10dp'
                size_hint_y: None
                height: self.minimum_height

            MDLabel:
                id: exercise_description
                text: "Опис Вправи"
                halign: "left"
                font_style: "Body1"
                padding: [10, 0]
                size_hint_y: None
                height: self.texture_size[1]

            Widget:

<MainExerciseScreen>:
    id: main_exerc
    name: "main_exercise"
    AnchorLayout:
        BoxLayout:
            orientation: "vertical"
            size_hint: None, None
            height: "230dp"
            width: "305dp"
            MDLabel:
                id: date_label
                text: root.current_date
                halign: "center"
                theme_text_color: "Primary"
                font_style: "H5"
            BoxLayout:
                size_hint: None, None
                height: "90dp"
                width: "305dp"
                spacing: "-35dp"
                MDIconButton:
                    icon: "chevron-left"
                    icon_size: "120sp"
                    on_release: root.prev_day()
                MDIcon:
                    icon: "weight-lifter"
                    pos_hint: {"center_x": 0.5, "center_y":0.85}
                    font_size: "90sp"
                MDIconButton:
                    icon: "chevron-right"
                    icon_size: "120sp"
                    on_release: root.next_day()
            MDRaisedButton:
                text: "Почати тренування"
                pos_hint: {"center_x": 0.51}
                on_release: root.manager.start_workout();

    AnchorLayout:
        anchor_x: "right"
        anchor_y: "top"
        MDIconButton:
            icon: "calendar-check"
            style: "outlined"
            icon_size: "48sp"

<WorkoutProgramsScreen>:
    name: 'workout_programs'
    BoxLayout:
        orientation: 'vertical'
        ScrollView:
            MDList:
                id: programs_list
        MDRaisedButton:
            text: "Створити програму тренувань"
            pos_hint: {"center_x": 0.5}
            on_release: root.manager.push("create_program", "Створення програми")

<ProgramsNotFoundScreen@Screen>:
    name: 'program_not_found'
    AnchorLayout:
        BoxLayout:
            orientation: 'vertical'
            size_hint: None, None
            size: dp(450), dp(100)
            spacing: dp(10)
            MDLabel:
                text: "Немає програм тренувань для цього дня."
                halign: 'center'
                font_style: "H6"
            MDRaisedButton:
                text: "Створити програму тренувань"
                pos_hint: {'center_x': 0.5}
                on_release: root.manager.push("create_program", "Створення програми")

<CreateProgramScreen>:
    name: "create_program"
    BoxLayout:
        orientation: 'vertical'
        padding: '10dp'
        spacing: '10dp'
        MDTextFieldLettersNumsSpacing:
            id: program_name
            input_filter: self.insert_filter
            required: True
            helper_text: "Введіть назву"
            max_text_length: 30
            hint_text: "Назва програми"
            mode: "rectangle"
        ScrollView:
            MDList:
                id: muscle_groups_list
        MDRaisedButton:
            text: "Зберегти програму"
            pos_hint: {'center_x': 0.5}
            on_release: root.save_program()
