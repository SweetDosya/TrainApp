<MainAppScreenManager>:
    ScreenNewUser:
    MainAppPage:
        name: "main_app_menu"
        id: main_menu

<MainAppPage>:
    id: main_menu
    MDBoxLayout:
        orientation: 'vertical'

        MDTopAppBar:
            id: top_bar
            title: main_menu.bar_name
            anchor_title: "left"
            right_action_items: [["theme-light-dark", lambda x: app.switch_theme()]]

        MainAppNavigationBarManager:
            id: main_nav_bar_manager
            size_hint_y: 5.2

            ExercisesScreen:
                id: main_exerc
                name: "main_exercise"

            ProfileScreen:
                name: "profile"

            InfoScreen:
                name: "info"

        MDBottomNavigation:
            id: bottom_nav
            selected_color_background: app.theme_cls.bg_normal
            elevation: 5
            height: self.minimum_height
            MDBottomNavigationItem:
                name: "main_tab"
                text: "Головна"
                icon: 'home-variant'
                on_tab_press: main_menu.change_tab_screen(self, "main_exercise")
            MDBottomNavigationItem:
                name: "profile_tab"
                text: "Профіль"
                icon: 'account'
                on_tab_press: main_menu.change_tab_screen(self, "profile")
            MDBottomNavigationItem:
                name: "note_tab"
                text: "Інформація"
                icon: 'notebook'
                on_tab_press: main_menu.change_tab_screen(self, "info")

<ExercisesScreen@Screen>:
    id: main_exercs
    name: "main_exercises"

    NavigationExerciseManager:
        id: exerc_manager
        name: "exercise_manager"

        CreateProgramScreen:

        ProgramsNotFoundScreen:

        MainExerciseScreen:
            id: main_exerc
            name: "main_exercise"

        WorkoutProgramsScreen:



<MainExerciseScreen>:
    id: main_exerc
    name: "main_exercise"
    AnchorLayout:
        BoxLayout:
            orientation: "vertical"
            size_hint: None, None
            height: "230dp"
            width: "305dp"
            MDLabel:
                id: date_label
                text: root.current_date
                halign: "center"
                theme_text_color: "Primary"
                font_style: "H5"
            BoxLayout:
                size_hint: None, None
                height: "90dp"
                width: "305dp"
                spacing: "-35dp"
                MDIconButton:
                    icon: "chevron-left"
                    icon_size: "120sp"
                    on_release: root.manager.prev_day()
                MDIcon:
                    icon: "weight-lifter"
                    pos_hint: {"center_x": 0.5, "center_y":0.85}
                    font_size: "90sp"
                MDIconButton:
                    icon: "chevron-right"
                    icon_size: "120sp"
                    on_release: root.manager.next_day()
            MDRaisedButton:
                text: "Почати тренування"
                pos_hint: {"center_x": 0.51}
                on_release: root.manager.start_workout()

    AnchorLayout:
        anchor_x: "right"
        anchor_y: "top"
        MDIconButton:
            icon: "calendar-check"
            style: "outlined"
            icon_size: "48sp"

<WorkoutProgramsScreen@Screen>:
    name: 'workout_programs'
    BoxLayout:
        orientation: 'vertical'
        ScrollView:
            MDList:
                id: programs_list
        MDRaisedButton:
            text: "Створити програму тренувань"
            pos_hint: {"center_x": 0.5}
            on_release: app.create_new_program()

<ProgramsNotFoundScreen@Screen>:
    name: 'program_not_found'
    AnchorLayout:
        BoxLayout:
            orientation: 'vertical'
            size_hint: None, None
            size: dp(450), dp(100)
            spacing: dp(10)
            MDLabel:
                text: "Немає програм тренувань для цього дня."
                halign: 'center'
                font_style: "H6"
            MDRaisedButton:
                text: "Створити програму тренувань"
                pos_hint: {'center_x': 0.5}
                on_release: root.manager.create_program()

<CreateProgramScreen>:
    name: "create_program"
    BoxLayout:
        orientation: 'vertical'
        padding: '10dp'
        spacing: '10dp'
        MDTextFieldLetters:
            id: program_name
            input_filter: self.insert_filter
            required: True
            helper_text: "Введіть назву"
            max_text_length: 30
            hint_text: "Назва програми"
            mode: "rectangle"
        ScrollView:
            MDList:
                id: muscle_groups_list
        MDRaisedButton:
            text: "Зберегти програму"
            pos_hint: {'center_x': 0.5}
            on_release: root.save_program()

<InfoScreen>:
    id: info
    name: "info"
    ScrollView:
        BoxLayout:
            orientation: 'vertical'
            padding: '20dp'
            spacing: '20dp'

            MDCard:
                ripple_behavior: True
                style: "outlined"
                elevation: 10
                padding: '10dp'
                on_release: info.show_imt_info()

                BoxLayout:
                    orientation: 'vertical'
                    padding: '10dp'
                    spacing: '10dp'

                    BoxLayout:
                        orientation: 'horizontal'

                        MDLabel:
                            text: "Індекс маси тіла (ІМТ)"
                            halign: "center"
                            font_style: "H5"
                            size_hint_x: 0.9

                        MDIcon:
                            icon: "chevron-down"
                            pos_hint: {"center_y": 0.9, "center_x": 0.75}
                            size_hint_x: 0.1

                    MDLabel:
                        id: imt_value
                        halign: "center"
                        font_style: "H4"
                        theme_text_color: "Custom"
                        text_color: 1, 0, 0, 1

                    MDLabel:
                        id: imt_category
                        text: "Надмірна вага"
                        halign: "center"
                        font_style: "H6"

            MDCard:
                ripple_behavior: True
                style: "outlined"
                elevation: 10
                padding: '10dp'
                on_release: info.show_brm_info()

                BoxLayout:
                    orientation: 'vertical'
                    padding: '10dp'
                    spacing: '10dp'

                    BoxLayout:
                        orientation: 'horizontal'

                        MDLabel:
                            text: "Базальний рівень метаболізму\n(БРМ)"
                            halign: "center"
                            font_style: "H5"
                            size_hint_x: 0.9

                        MDIcon:
                            icon: "chevron-down"
                            pos_hint: {"center_y": 0.9, "center_x": 0.75}
                            size_hint_x: 0.1

                    MDLabel:
                        id: brm_value
                        halign: "center"
                        font_style: "H4"
                        theme_text_color: "Custom"
                        text_color: 0, 1, 0, 1

<ProfileScreen>:
    id: profile
    name: "profile"
    BoxLayout:
        padding: "15dp"
        spacing: "20dp"
        orientation: "vertical"
        MDIcon:
            icon: "human-male" if profile.sex_field == "Чоловік" else "human-female"
            style: "filled"
            font_size: "90sp"
            pos_hint: {"center_x": 0.5}
        GridLayout:
            cols: 2
            padding: "10dp"
            spacing: "30dp"
            size_hint_y: None
            height: self.minimum_height
            MDTextFieldLetters:
                mode: "rectangle"
                id: name
                hint_text: "Ім'я"
                #helper_text: "Введіть ім'я"
                input_filter: self.insert_filter
                max_text_length: 15
                text: profile.name_field
            MDTextFieldLetters:
                mode: "rectangle"
                id: sec_name
                hint_text: "Прізвище"
                input_filter: self.insert_filter
                #helper_text: "Введіть прізвище"
                max_text_length: 20
                text: profile.sec_name_field
            MDTextField:
                mode: "rectangle"
                #helper_text: "Введіть зріст в см"
                id: height
                readonly: True
                hint_text: "Зріст"
                # if self.focus: root.open_menu(height, (140, 210))
                text: profile.height_field
            MDTextField:
                mode: "rectangle"
                #helper_text: "Введіть вагу в кг"
                id: weight
                readonly: True
                hint_text: "Вага"
                # if self.focus: root.open_menu(weight, (30, 250))
                text: profile.weight_field
            MDTextField:
                mode: "rectangle"
                id: age
                #helper_text: "Введіть вік"
                hint_text: "Вік"
                # if self.focus: root.open_menu(age, (12, 124))
                text: profile.age_field
            MDTextField:
                mode: "rectangle"
                id: sex
                readonly: True
                #helper_text: "Оберіть стать"
                hint_text: "Стать"
                text: profile.sex_field
        MDRaisedButton:
            text: "Зберегти"
            pos_hint: {"center_x": 0.5, "top": 1.5}
            # on_release: app.save_profile()

<ScreenNewUser>:
    md_bg_color: app.theme_cls.primary_color
    MDCard:
        size_hint: 0.8, 0.6
        pos_hint: {'center_x': 0.5, 'center_y': 0.5}
        elevation: 5
        MDBoxLayout:
            orientation: "vertical"
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}
            padding: dp(15)
            MDLabel:
                id: welcome_label
                text: "Вітаємо в TrainApp!"
                halign: 'center'
                theme_text_color: 'Primary'
                font_style: 'H5'
                size_hint_y: None
                height: self.texture_size[1]

            NewUserScreenManager:
                id: new_user_manager

<NewUserScreenManager>:
    GeneralUserData:
        id: general_user_data_new
        name: "general_data"
    PhysicalUserData:
        id: physic_user_data_new
        name: "physic_data"

<GeneralUserData>:
    MDBoxLayout:
        id: box_gen_data
        orientation: "vertical"
        padding: dp(5)
        spacing: dp(15)
        MDTextFieldLetters:
            id: first_name
            hint_text: "Ім'я"
            input_filter: self.insert_filter
            required: True
            helper_text: "Введіть ім'я"
            size_hint_x: 0.5
            pos_hint: {'center_x': 0.5}
            max_text_length: 15

        MDTextFieldLetters:
            id: second_name
            hint_text: "Прізвище"
            required: True
            input_filter: self.insert_filter
            helper_text: "Введіть прізвище"
            size_hint_x: 0.5
            pos_hint: {'center_x': 0.5}
            max_text_length: 20

        MDBoxLayout:
            size_hint_x: 0.5
            spacing: dp(30)
            pos_hint: {"center_x": 0.4}
            SexUserToggleButton:
                group: 'gender'
                text: "Чоловік"
                icon: "gender-male"
                pos_hint: {"center_y": 0.5}
                on_release: root.update_gender("Чоловік")
            SexUserToggleButton:
                group: 'gender'
                text: "Жінка"
                icon: 'gender-female'
                pos_hint: {"center_y": 0.5}
                on_release: root.update_gender("Жінка")

        MDRaisedButton:
            text: "Далі"
            pos_hint: {"center_x": 0.5}
            on_release: root.update_name(first_name); root.update_sec_name(second_name); root.process_data()


<PhysicalUserData>:
    MDBoxLayout:
        orientation: "vertical"
        padding: dp(5)
        spacing: dp(15)
        MDTextField:
            id: user_data_age
            hint_text: "Вік"
            required: True
            helper_text: "Введіть вік"
            size_hint_x: 0.5
            pos_hint: {'center_x': 0.5}
            readonly: True
            on_focus: if self.focus: root.open_menu(user_data_age, (12, 124))

        MDTextField:
            id: user_data_height
            hint_text: "Зріст (см)"
            required: True
            helper_text: "Введіть зріст в см"
            size_hint_x: 0.5
            readonly: True
            pos_hint: {'center_x': 0.5}
            on_focus: if self.focus: root.open_menu(user_data_height, (140, 210))

        MDTextField:
            id: user_data_weight
            hint_text: "Вага (кг)"
            required: True
            helper_text: "Введіть вагу в кг"
            size_hint_x: 0.5
            readonly: True
            pos_hint: {'center_x': 0.5}
            on_focus: if self.focus: root.open_menu(user_data_weight, (30, 250))

        MDRaisedButton:
            text: "Зберегти"
            pos_hint: {"center_x": 0.5}
            on_release:
                root.update_name(user_data_age);
                root.update_sec_name(user_data_height);
                root.update_gender(user_data_weight);
                root.process_data();
